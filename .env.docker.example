# ─────────────────────────────────────────────────────────────
# Secrets for `docker compose up` (cloud Supabase).
# Copy this file to `.env.docker` and fill in the real values.
# `.env.docker` is gitignored — NEVER commit real secrets.
# Ask the project owner for the real values (shared privately).
# ─────────────────────────────────────────────────────────────

# Cloud Supabase Postgres (Mumbai). Pooled (6543) for the app, direct (5432) for migrations.
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# Auth
JWT_SECRET="<a-long-random-string>"
JWT_EXPIRES_IN="7d"

# Seed admin (only used if you intentionally run `npm run db:seed`)
SEED_ADMIN_EMAIL="admin@namanpuja.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# Atomic CRM sync — write bookings into the live CRM as contacts + deals.
CRM_ENABLED="true"
SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<sb_secret_...>"
CRM_DEFAULT_SALES_ID="1"
