# ─────────────────────────────────────────────────────────────
# namanpuja.com — Backend environment configuration
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins (frontend + admin panel)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database (Supabase Postgres — shared with Atomic CRM) ──
# Use the "Connection pooling" string (port 6543) for the app,
# and the direct connection (port 5432) for migrations.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ── Auth ──
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Seed admin (created by `npm run db:seed`)
SEED_ADMIN_EMAIL=admin@namanpuja.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# ── Atomic CRM integration (Supabase service role) ──
# Bookings are written into Atomic CRM's contacts + deals tables.
CRM_ENABLED=false
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# The CRM sales rep id that owns inbound bookings (Atomic CRM `sales.id`)
CRM_DEFAULT_SALES_ID=1
